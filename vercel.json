{
  "buildCommand": "cd managed-chatkit/frontend && npm run build",
  "outputDirectory": "managed-chatkit/frontend/dist",
  "installCommand": "cd managed-chatkit/frontend && npm install",
  "framework": "vite",
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
