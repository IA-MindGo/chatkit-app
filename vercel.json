{
  "buildCommand": "npm --prefix managed-chatkit/frontend run build",
  "outputDirectory": "managed-chatkit/frontend/dist",
  "installCommand": "npm install --prefix managed-chatkit/frontend",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
